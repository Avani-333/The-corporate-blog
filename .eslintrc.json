{
  "extends": [
    "next/core-web-vitals"
  ],
  "rules": {
    "prefer-const": "error",
    "no-var": "error",
    "react/no-unescaped-entities": "off",
    "@next/next/no-img-element": "off",
    "import/no-anonymous-default-export": "off",
    "jsx-a11y/alt-text": "off",
    "react-hooks/exhaustive-deps": "off"
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "out/",
    "build/"
  ]
}