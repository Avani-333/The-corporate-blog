# Production Environment - Database Configuration
# For production deployment with connection pooling

# ============================================================================
# CRITICAL SECURITY: Copy this file to .env.production (DO NOT commit to Git)
# ============================================================================

# Database Configuration
POSTGRES_PRISMA_URL=postgresql://user:password@host:5432/database?pgbouncer=true&connection_limit=25
POSTGRES_URL_NON_POOLING=postgresql://user:password@host:5432/database

# Database Pool Settings (Production)
DB_CONNECTION_LIMIT=25
DB_ACQUIRE_TIMEOUT=30000
DB_CREATE_TIMEOUT=30000  
DB_DESTROY_TIMEOUT=5000
DB_IDLE_TIMEOUT=300000
DB_REAP_INTERVAL=1000

# SSL Configuration
DB_SSL_REQUIRE=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Query Configuration
DB_QUERY_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=45000
DB_LOCK_TIMEOUT=60000
DB_IDLE_IN_TRANSACTION_TIMEOUT=300000

# Monitoring
DB_ENABLE_METRICS=true
DB_SLOW_QUERY_THRESHOLD=1000
DB_HEALTH_CHECK_INTERVAL=30000
DB_MAX_CONNECTION_AGE=3600000

# Application Configuration
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://thecorporateblog.com
NEXT_PUBLIC_CDN_URL=https://cdn.thecorporateblog.com

# Authentication Secrets (KEEP THESE SECRET!)
NEXTAUTH_SECRET=your-super-secret-key-here
NEXTAUTH_URL=https://thecorporateblog.com
JWT_SECRET=your-jwt-secret-here-minimum-32-characters
REFRESH_SECRET=your-refresh-secret-here-minimum-32-characters

# Google OAuth (Get from https://console.developers.google.com)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-keep-secret

# External Services
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=thecorporateblog

# ============================================================================
# SOURCE MAP SECURITY & SENTRY CONFIGURATION
# ============================================================================

# Source Maps are DISABLED in production builds by default
# If source maps needed for debugging, upload to Sentry instead (see below)

# Sentry Error Tracking (optional but recommended)
# Get from: https://sentry.io
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# Sentry Source Map Upload (for error tracking with source maps)
# Create auth token at: https://sentry.io/settings/auth-tokens/
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=sntrys_your-token-here  # Keep this secret!

# Git commit SHA for release tracking (usually set by CI/CD)
# On Vercel: automatically set to VERCEL_GIT_COMMIT_SHA
VERCEL_GIT_COMMIT_SHA=auto

# ============================================================================
# ANALYTICS & MONITORING
# ============================================================================

NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-id

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@thecorporateblog.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=noreply@thecorporateblog.com

# ============================================================================
# SECURITY FEATURES
# ============================================================================

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-namespace-your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Redis for token blacklist (optional but recommended)
REDIS_URL=redis://user:password@host:port/db
REDIS_PASSWORD=your-redis-password

# CSP Nonce Secret
CSP_NONCE_SECRET=your-csp-nonce-secret

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Vercel
VERCEL=1
VERCEL_ENV=production
VERCEL_URL=thecorporateblog.com

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_TRACKING=true

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# 1. NEVER commit this file to Git. It's in .gitignore.
# 2. Store secrets in your deployment platform (Vercel, Railway, etc.)
# 3. Source maps are disabled in production - errors logged to Sentry instead
# 4. For local development debugging, use .env.local with sourceMap: true
# 5. Rotate SENTRY_AUTH_TOKEN regularly - treat it like a password
# ============================================================================
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# Google Search Console API integration
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:thecorporateblog.com
GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=
SEARCH_CONSOLE_ADMIN_TOKEN=

# Redis (for caching)
REDIS_URL=redis://user:password@host:6379

# Feature Flags
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SEARCH=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NEWSLETTER=true