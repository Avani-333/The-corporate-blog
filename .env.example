# =============================================================================
# THE CORPORATE BLOG - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# -----------------------------------------------------------------------------
# DATABASE (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Get this from: https://console.neon.tech
# Format: postgresql://username:password@hostname/database_name?sslmode=require
DATABASE_URL="postgresql://username:password@hostname/database_name?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://username:password@hostname/database_name?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://username:password@hostname/database_name?sslmode=require"

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# Generate a random 32 character string for NEXTAUTH_SECRET
# You can use: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# JWT Configuration (REQUIRED)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production-minimum-32-characters"
REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-minimum-32-characters"

# Google OAuth (get from: https://console.developers.google.com)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Password Security
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Session Configuration
SESSION_MAX_AGE=604800  # 7 days in seconds
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# -----------------------------------------------------------------------------
# MEDIA STORAGE (Cloudinary)
# -----------------------------------------------------------------------------
# Get these from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# -----------------------------------------------------------------------------
# ANALYTICS & MONITORING
# -----------------------------------------------------------------------------
# Vercel Analytics (automatically set by Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID="your-analytics-id"

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Cloudflare Web Analytics (optional)
NEXT_PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN=""

# Google Search Console API integration (optional)
GOOGLE_SEARCH_CONSOLE_SITE_URL="sc-domain:thecorporateblog.com"
GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=""
SEARCH_CONSOLE_ADMIN_TOKEN=""

# Sentry (optional - for error tracking)
SENTRY_DSN="your-sentry-dsn"
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"

# -----------------------------------------------------------------------------
# EMAIL (for notifications)
# -----------------------------------------------------------------------------
# SMTP Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@thecorporateblog.com"

# -----------------------------------------------------------------------------
# SITE CONFIGURATION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="The Corporate Blog"
NEXT_PUBLIC_SITE_DESCRIPTION="Production-grade, SEO-first, serverless blogging platform"

# -----------------------------------------------------------------------------
# API RATE LIMITING
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# -----------------------------------------------------------------------------
# SEARCH (Algolia - optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ALGOLIA_APP_ID="your-algolia-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY="your-algolia-search-key"
ALGOLIA_ADMIN_KEY="your-algolia-admin-key"

# -----------------------------------------------------------------------------
# DEPLOYMENT
# -----------------------------------------------------------------------------
NODE_ENV="development"
VERCEL="0"
VERCEL_URL=""

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# CSP Nonce (Content Security Policy)
CSP_NONCE_SECRET="your-csp-nonce-secret"

# Rate limiting
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="900000"