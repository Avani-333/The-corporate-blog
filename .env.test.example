# Test Environment - Database Configuration
# For automated testing

# Database Configuration (Test Database)
DATABASE_URL=postgresql://postgres:password@localhost:5432/thecorporateblog_test
POSTGRES_PRISMA_URL=postgresql://postgres:password@localhost:5432/thecorporateblog_test
POSTGRES_URL_NON_POOLING=postgresql://postgres:password@localhost:5432/thecorporateblog_test

# Database Pool Settings (Test)
DB_CONNECTION_LIMIT=2
DB_ACQUIRE_TIMEOUT=5000
DB_CREATE_TIMEOUT=5000
DB_DESTROY_TIMEOUT=1000
DB_IDLE_TIMEOUT=60000
DB_REAP_INTERVAL=1000

# SSL Configuration (Test)
DB_SSL_REQUIRE=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Query Configuration
DB_QUERY_TIMEOUT=10000
DB_STATEMENT_TIMEOUT=15000
DB_LOCK_TIMEOUT=30000
DB_IDLE_IN_TRANSACTION_TIMEOUT=60000

# Monitoring (Test)
DB_ENABLE_METRICS=false
DB_SLOW_QUERY_THRESHOLD=500
DB_HEALTH_CHECK_INTERVAL=10000
DB_MAX_CONNECTION_AGE=1800000

# Application Configuration
NODE_ENV=test
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_CDN_URL=http://localhost:3000

# Authentication (Test)
NEXTAUTH_SECRET=test-secret-key
NEXTAUTH_URL=http://localhost:3000

# External Services (Test - Use mocks)
CLOUDINARY_CLOUD_NAME=test_cloud
CLOUDINARY_API_KEY=test_key
CLOUDINARY_API_SECRET=test_secret
CLOUDINARY_UPLOAD_PRESET=test_preset

# Feature Flags (Test)
NEXT_PUBLIC_ENABLE_COMMENTS=true
NEXT_PUBLIC_ENABLE_SEARCH=false
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_NEWSLETTER=false
NEXT_PUBLIC_USE_MOCK_DATA=true