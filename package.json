{
  "name": "the-corporate-blog",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade, SEO-first, serverless blogging platform",
  "keywords": [
    "next.js",
    "blog",
    "cms",
    "seo",
    "typescript",
    "prisma"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && npm run verify:security",
    "build:prod": "NODE_ENV=production next build && npm run verify:security",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postbuild": "next-sitemap",
    "verify:security": "node scripts/verify-build-security.js",
    "analyze": "ANALYZE=true npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset && npm run db:seed",
    "db:setup": "prisma generate && prisma db push && npm run db:seed",
    "vercel:build": "prisma generate && next build",
    "migrate:status": "node scripts/migrate.js status",
    "migrate:generate": "node scripts/migrate.js generate",
    "migrate:apply": "node scripts/migrate.js apply",
    "migrate:rollback": "node scripts/migrate.js rollback",
    "migrate:reset": "node scripts/migrate.js reset",
    "migrate:backup": "node scripts/migrate.js backup",
    "migrate:restore": "node scripts/migrate.js restore",
    "migrate:validate": "node scripts/migrate.js validate",
    "db:health-check": "node -e \"require('./lib/database/connection.ts').getConnectionStatus().then(console.log)\"",
    "db:monitor": "node -e \"setInterval(()=>require('./lib/database/connection.ts').getConnectionStatus().then(console.log),5000)\"",
    "export:weekly": "node scripts/weekly-export.js",
    "export:weekly:cron": "bash scripts/weekly-export-cron.sh",
    "export:manual": "VERBOSE=true node scripts/weekly-export.js",
    "export:manage": "node scripts/export-manager.js",
    "benchmark": "node scripts/benchmark-cli.js",
    "benchmark:audit": "node scripts/benchmark-cli.js audit",
    "benchmark:seo": "node scripts/benchmark-cli.js seo-audit",
    "benchmark:monitor": "node scripts/benchmark-cli.js monitor",
    "benchmark:report": "node scripts/benchmark-cli.js report",
    "validate:lighthouse": "ts-node scripts/lighthouse-validator.ts http://localhost:3000",
    "validate:lighthouse:mobile": "ts-node scripts/lighthouse-validator.ts http://localhost:3000 --mobile-only",
    "validate:lighthouse:desktop": "ts-node scripts/lighthouse-validator.ts http://localhost:3000 --desktop-only",
    "validate:lighthouse:local": "npm run build && npm run start & sleep 5 && npm run validate:lighthouse && npm run validate:lighthouse:analyze",
    "validate:lighthouse:analyze": "node scripts/analyze-lighthouse-reports.js",
    "validate:performance": "node scripts/validate-performance.js http://localhost:3000",
    "validate:performance:prod": "node scripts/validate-performance.js https://thecorporateblog.com",
    "validate:all": "npm run validate:lighthouse && npm run validate:performance",
    "lighthouse": "lighthouse --output=json --output=html --output-path=./lighthouse-reports/report",
    "seo:validate": "node scripts/benchmark-cli.js validate-seo",
    "seo:generate": "node scripts/benchmark-cli.js generate-metadata",
    "perf:audit": "npm run benchmark:audit http://localhost:3000",
    "perf:full": "npm run build && npm run start & sleep 30 && npm run perf:audit && pkill -f 'next start'",
    "load-test": "bash scripts/load-test/run-load-tests.sh",
    "load-test:sustained": "k6 run --scenario=sustained-load-2k-users scripts/load-test/load-test.ts",
    "load-test:publish": "k6 run --scenario=publish-burst scripts/load-test/load-test.ts",
    "load-test:search": "k6 run --scenario=search-burst scripts/load-test/load-test.ts",
    "load-test:coldstart": "k6 run --scenario=cold-start scripts/load-test/load-test.ts",
    "load-test:analyze": "node scripts/load-test/analyze-results.js",
    "load-test:report": "node scripts/load-test/generate-report.js",
    "load-test:lcp": "k6 run scripts/load-test/lcp-memory-validator.ts",
    "load-test:memory": "k6 run --vus=5 --duration=60s scripts/load-test/lcp-memory-validator.ts",
    "load-test:validation": "npm run build && npm run load-test:lcp && npm run load-test:memory",
    "dev:memory-monitoring": "NEXT_PUBLIC_MEMORY_LEAK_DETECTION=true npm run dev",
    "test:memory-leaks": "NEXT_PUBLIC_MEMORY_LEAK_DETECTION=true npm run dev"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^16.5.0",
    "@hookform/resolvers": "^3.3.4",
    "@next/bundle-analyzer": "^14.1.0",
    "@prisma/client": "^5.9.0",
    "@sentry/nextjs": "^10.44.0",
    "@vercel/analytics": "^1.1.1",
    "@vercel/speed-insights": "^1.0.7",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0-rc.12",
    "chrome-launcher": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "cloudinary": "^2.0.1",
    "clsx": "^2.1.0",
    "commander": "^11.1.0",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.5",
    "google-auth-library": "^9.6.3",
    "gray-matter": "^4.0.3",
    "jose": "^5.2.0",
    "lighthouse": "^11.4.0",
    "lucide-react": "^0.344.0",
    "next": "^14.1.0",
    "next-auth": "^4.24.5",
    "next-cloudinary": "^5.20.0",
    "next-themes": "^0.2.1",
    "ora": "^8.0.1",
    "pg": "^8.11.3",
    "prisma": "^5.9.0",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "react-intersection-observer": "^9.8.1",
    "reading-time": "^1.5.0",
    "rehype-highlight": "^7.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-html": "^16.0.1",
    "sharp": "^0.33.2",
    "tailwind-merge": "^2.2.1",
    "tsx": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.17",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.2.55",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "prisma": "^5.9.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
